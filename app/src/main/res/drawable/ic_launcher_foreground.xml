        android:pathData="M25,68 A32,32,0,0,1,51,22" />

    <!-- Arrowhead at A (54,22) — clockwise direction at top is RIGHT -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,22 L47,17 L47,27 Z" />

    <!-- Arc 2: from after-A (275°, 57,22) to before-B (25°, 83,68) -->
    <path
        android:fillColor="#00000000"
